datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  settings  Setting?
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  orgId     String

  org Organization @relation(fields: [orgId], references: [id])
}

model Product {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  sku         String
  description String?
  quantity    Int
  costPrice   Float?
  sellPrice   Float?
  lowStock    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, sku])
}

model Setting {
  id               String @id @default(uuid())
  orgId            String @unique
  defaultLowStock  Int    @default(5)

  org Organization @relation(fields: [orgId], references: [id])
}
